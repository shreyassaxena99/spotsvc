# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase Postgres — use connection pooler URL (port 6543) for PgBouncer
SUPABASE_DB_URL=postgresql+asyncpg://postgres.your-project-ref:password@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# Google Places API (New)
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# App
APP_ENV=development
